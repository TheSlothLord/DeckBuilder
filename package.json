{
  "name": "deckbuilder",
  "version": "1.6.2",
  "private": true,
  "type": "module",
  "description": "Decking plank layout & cut optimizer",
  "author": "DeckBuilder",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron": "electron .",
    "app:build": "tsc -b && vite build",
    "dist:win": "npm run app:build && electron-builder --win",
    "android:sync": "npm run app:build && cap copy android",
    "android:apk": "npm run android:sync && cd android && .\\gradlew.bat assembleDebug"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.deckbuilder.app",
    "productName": "DeckBuilder",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "zip",
      "signAndEditExecutable": false,
      "artifactName": "DeckBuilder-${version}-win-x64.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/share": "^7.0.4"
  }
}
